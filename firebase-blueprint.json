{
  "entities": {
    "Service": {
      "title": "Service",
      "description": "A farming service offered by Kaliyapa Farmstead.",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "description": { "type": "string" },
        "image": { "type": "string" },
        "features": { 
          "type": "array",
          "items": { "type": "string" }
        },
        "order": { "type": "number" }
      },
      "required": ["title", "description", "image", "features"]
    },
    "Testimonial": {
      "title": "Testimonial",
      "description": "Customer feedback and reviews.",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "role": { "type": "string" },
        "text": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "text"]
    },
    "GalleryImage": {
      "title": "Gallery Image",
      "description": "Visuals of the farm and livestock.",
      "type": "object",
      "properties": {
        "url": { "type": "string" },
        "category": { "type": "string" },
        "title": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["url", "category", "title"]
    },
    "Inquiry": {
      "title": "Inquiry",
      "description": "Contact form submissions from potential clients.",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "email": { "type": "string" },
        "phone": { "type": "string" },
        "interest": { "type": "string" },
        "message": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "email", "message", "createdAt"]
    }
  },
  "firestore": {
    "services": {
      "schema": "Service",
      "description": "Collection of farming services."
    },
    "testimonials": {
      "schema": "Testimonial",
      "description": "Collection of customer testimonials."
    },
    "gallery": {
      "schema": "GalleryImage",
      "description": "Collection of gallery images."
    },
    "inquiries": {
      "schema": "Inquiry",
      "description": "Collection of user inquiries."
    }
  }
}
